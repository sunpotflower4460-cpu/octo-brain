{
  "name": "octo-brain-workers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:bench": "tsc -p bench/tsconfig.json --noEmit",
    "bench": "tsx bench/main.ts",
